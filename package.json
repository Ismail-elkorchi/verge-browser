{
  "name": "@ismail-elkorchi/verge-browser",
  "version": "0.1.2",
  "description": "Terminal browsing primitives with safe fetch helpers, HTML snapshots, and auditable text rendering.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ismail-elkorchi/verge-browser.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "packageManager": "npm@11.10.0",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "bin": {
    "verge": "./dist/cli.js"
  },
  "main": "./dist/mod.js",
  "types": "./dist/mod.d.ts",
  "exports": {
    ".": {
      "types": "./dist/mod.d.ts",
      "import": "./dist/mod.js"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node scripts/build/clean-dist.mjs && tsc -p tsconfig.build.json",
    "check": "npm run lint && npm run typecheck && npm test && npm run smoke:cli && npm run eval:ci",
    "check:fast": "npm run lint && npm run typecheck && npm test && npm run docs:required && npm run docs:check:jsr && npm run examples:run",
    "ci": "npm run check",
    "ci:reliability:claim": "node scripts/ci/sample-node-reliability.mjs --mode=rolling --window-count=3 --events=push,pull_request --event-sample-sizes=push:5,pull_request:9 --confidence=0.95 --require-non-overlap",
    "ci:reliability:sample": "node scripts/ci/sample-node-reliability.mjs --mode=rolling --window-count=3",
    "ci:reliability:sample:local": "node scripts/ci/sample-node-reliability.mjs --mode=rolling --window-count=3 --sample-size=10 --confidence=0.95",
    "ci:reliability:sample:stratified": "node scripts/ci/sample-node-reliability.mjs --mode=rolling --window-count=3 --events=push,pull_request --event-sample-sizes=push:5,pull_request:9 --confidence=0.95",
    "corpus:render": "node scripts/oracles/corpus/generate-render-v3.mjs",
    "eval:capability-ladder:ci": "npm run build && node scripts/eval/write-capability-ladder-report.mjs --profile=ci",
    "eval:capability-ladder:release": "npm run build && node scripts/eval/write-capability-ladder-report.mjs --profile=release",
    "eval:ci": "npm run build && node scripts/eval/run-eval.mjs --profile=ci",
    "eval:oracle-fingerprint:ci": "npm run build && node scripts/eval/run-oracle-fingerprint-drift-check.mjs --profile=ci",
    "eval:oracle-fingerprint:release": "npm run build && node scripts/eval/run-oracle-fingerprint-drift-check.mjs --profile=release",
    "eval:oracle-lock-refresh-diff:ci": "npm run build && node scripts/eval/check-oracle-lock-refresh-diff.mjs --profile=ci",
    "eval:oracle-lock-refresh-diff:release": "npm run build && node scripts/eval/check-oracle-lock-refresh-diff.mjs --profile=release",
    "eval:oracle-runtime:ci": "npm run build && node scripts/eval/run-oracle-runtime-validation.mjs --profile=ci",
    "eval:oracle-runtime:release": "npm run build && node scripts/eval/run-oracle-runtime-validation.mjs --profile=release",
    "eval:oracle-superiority:ci": "npm run build && node scripts/eval/run-oracle-superiority-check.mjs --profile=ci",
    "eval:oracle-superiority:release": "npm run build && node scripts/eval/run-oracle-superiority-check.mjs --profile=release",
    "eval:oracle-supply-chain:ci": "npm run build && node scripts/eval/run-oracle-supply-chain-check.mjs --profile=ci",
    "eval:oracle-supply-chain:release": "npm run build && node scripts/eval/run-oracle-supply-chain-check.mjs --profile=release",
    "eval:wpt-delta": "npm run build && node scripts/eval/check-wpt-delta.mjs",
    "eval:fuzz:ci": "npm run build && node scripts/eval/run-fuzz-check.mjs --profile=ci",
    "eval:fuzz:release": "npm run build && node scripts/eval/run-fuzz-check.mjs --profile=release",
    "eval:fuzz-guided:ci": "npm run build && node scripts/eval/run-fuzz-guided-check.mjs --profile=ci",
    "eval:fuzz-guided:release": "npm run build && node scripts/eval/run-fuzz-guided-check.mjs --profile=release",
    "eval:release": "npm run build && node scripts/eval/run-eval.mjs --profile=release",
    "examples:run": "npm run build && node examples/run-all.mjs",
    "field:governance": "node scripts/realworld/check-cohort-governance.mjs",
    "field:layout:wpt": "npm run field:layout:wpt:fetch && npm run field:layout:wpt:run",
    "field:layout:wpt:fetch": "node scripts/realworld/layout/fetch-wpt-subset.mjs",
    "field:layout:wpt:run": "npm run build && node scripts/realworld/layout/run-layout-pilot.mjs",
    "field:offline": "npm run build && node scripts/realworld/run-offline-eval.mjs",
    "field:oracles": "npm run build && node scripts/realworld/run-oracles-offline.mjs",
    "field:report": "node scripts/realworld/summarize.mjs",
    "field:triage:fixtures": "npm run build && node scripts/realworld/classify-visible-text-residuals.mjs && node scripts/realworld/minimize-visible-text-residuals.mjs && node scripts/realworld/generate-visible-text-fixture-candidates.mjs",
    "field:triage:minimize": "npm run build && node scripts/realworld/minimize-visible-text-residuals.mjs",
    "field:triage:taxonomy": "npm run build && node scripts/realworld/classify-visible-text-residuals.mjs",
    "field:visible-text:ab": "npm run build && node scripts/realworld/compare-visible-text-policies.mjs",
    "mutation:pilot": "npm run build && node scripts/mutation/run-pilot.mjs --config=scripts/mutation/pilot-config.json --out=docs/maintainers/mutation-pilot-report.json",
    "deps:freshness": "npm outdated || true",
    "lint": "eslint . --max-warnings=0",
    "oracle:image:prepare": "node scripts/oracles/prepare-image.mjs",
    "oracle:lock:refresh": "node scripts/oracles/refresh-oracle-lock.mjs",
    "oracle:wpt-delta:corpus": "node scripts/oracles/corpus/refresh-wpt-delta-corpus.mjs",
    "oracle:wpt-delta:diff": "node scripts/oracles/corpus/diff-wpt-delta-refresh.mjs",
    "oracle:wpt-delta:refresh": "npm run build && node scripts/oracles/corpus/refresh-wpt-delta-expected.mjs",
    "docs:lint:jsr": "deno doc --lint --no-lock --sloppy-imports jsr/mod.ts",
    "docs:test:jsr": "deno test --doc --no-check --no-lock --sloppy-imports jsr/mod.ts",
    "docs:check:jsr": "npm run docs:lint:jsr && npm run docs:test:jsr && npm run docs:quality:jsr",
    "docs:html:jsr": "node scripts/quality/render-jsr-docs-html.mjs",
    "release:check": "npm run check && npm run eval:release && npm run eval:oracle-runtime:release && npm run eval:oracle-superiority:release && npm run eval:oracle-fingerprint:release && npm run eval:oracle-supply-chain:release && npm pack --dry-run",
    "smoke:all": "npm run smoke:node && npm run smoke:deno && npm run smoke:bun",
    "smoke:bun": "npm run build && bun scripts/smoke/runtime-smoke.mjs --runtime=bun --report=reports/smoke-bun.json",
    "smoke:cli": "node scripts/automation/smoke-cli.mjs",
    "smoke:deno": "npm run build && deno run --allow-read --allow-write=reports --allow-env --node-modules-dir=manual scripts/smoke/runtime-smoke.mjs --runtime=deno --report=reports/smoke-deno.json",
    "smoke:node": "npm run build && node scripts/smoke/runtime-smoke.mjs --runtime=node --report=reports/smoke-node.json",
    "start": "npm run build && node dist/cli.js",
    "test": "npm run build && node scripts/test/run-node-tests.mjs test/control",
    "test:bench": "npm run build && node scripts/bench/run-bench.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "docs:required": "node scripts/quality/doc-required.mjs",
    "docs:quality:jsr": "node scripts/quality/doc-jsr-quality.mjs",
    "release:notes:dry-run": "node scripts/release/render-notes.mjs --dry-run",
    "changelog:update:dry-run": "node scripts/release/update-changelog.mjs --dry-run"
  },
  "dependencies": {
    "@ismail-elkorchi/html-parser": "^0.1.0"
  },
  "devDependencies": {
    "@eslint/js": "9.39.3",
    "@types/node": "25.3.5",
    "eslint": "9.39.3",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1"
  },
  "overrides": {
    "ajv": "6.14.0",
    "eslint": {
      "minimatch": "3.1.5"
    },
    "@eslint/config-array": {
      "minimatch": "3.1.5"
    },
    "@eslint/eslintrc": {
      "minimatch": "3.1.5"
    },
    "@typescript-eslint/typescript-estree": {
      "minimatch": "9.0.9"
    }
  }
}
